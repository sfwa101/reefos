# ─── Supabase (client-visible, safe in browser) ────────────────────────
# Copy this file to `.env` and fill in your values to point the app at
# any Supabase project (Lovable Cloud, self-hosted, or supabase.com).
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-or-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Standard alias accepted by the generated client as a fallback. Either
# name works — keep both if you want maximum portability across IDEs.
VITE_SUPABASE_ANON_KEY="your-publishable-or-anon-key"

# ─── Supabase (server-only — NEVER expose to the browser) ──────────────
# Used by SSR / server functions / scripts/backup-db.ts and seeders.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-or-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
